{
  "info": {
    "name": "Real-Time Leaderboard System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Submit Score",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"playerId\": \"player-101\",\n  \"score\": 980\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaderboard/submit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "leaderboard",
            "submit"
          ]
        }
      }
    },
    {
      "name": "Get Top Players",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaderboard/top?limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "leaderboard",
            "top"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Get Player Rank",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaderboard/rank/player-101",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "leaderboard",
            "rank",
            "player-101"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
